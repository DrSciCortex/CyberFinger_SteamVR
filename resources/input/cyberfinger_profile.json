{
    "jsonid": "input_profile",
    "controller_type": "cyberfinger",
    "device_class": "TrackedDeviceClass_Controller",
    "resource_root": "cyberfinger",
    "driver_name": "cyberfinger",
    "input_bindingui_mode": "controller_handed",
    "input_bindingui_left": {
        "image": "{cyberfinger}/icons/controller_left.png"
    },
    "input_bindingui_right": {
        "image": "{cyberfinger}/icons/controller_right.png"
    },
    "input_source": {
        "/input/a": {
            "type": "button",
            "click": true,
            "touch": false,
            "binding_image_point": [ 100, 100 ],
            "order": 1
        },
        "/input/b": {
            "type": "button",
            "click": true,
            "touch": false,
            "binding_image_point": [ 200, 200 ],
            "order": 2
        },
        "/input/joystick": {
            "type": "joystick",
            "click": true,
            "touch": false,
            "binding_image_point": [ 100, 200 ],
            "order": 3
        },
        "/input/trigger": {
            "type": "button",
            "click": true,
            "touch": false,
            "binding_image_point": [ 200, 100 ],
            "order": 4
        },
        "/input/grip": {
            "type": "button",
            "click": true,
            "touch": false,
            "binding_image_point": [ 50, 50 ],
            "order": 5
        },
        "/input/skeleton/left": {
            "type": "skeleton",
            "skeleton": "/skeleton/hand/left",
            "order": 20
        },
        "/input/skeleton/right": {
            "type": "skeleton",
            "skeleton": "/skeleton/hand/right",
            "order": 21
        }
    }
}
