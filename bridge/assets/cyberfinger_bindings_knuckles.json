{
  "controller_type": "knuckles",
  "name": "CyberFinger skeleton (Index)",
  "description": "Hand skeleton bindings for the CyberFinger Bridge display",
  "bindings": {
    "/actions/cyberfinger": {
      "skeleton": [
        {
          "output": "/actions/cyberfinger/in/skeleton_left",
          "path": "/user/hand/left/input/skeleton/left"
        },
        {
          "output": "/actions/cyberfinger/in/skeleton_right",
          "path": "/user/hand/right/input/skeleton/right"
        }
      ]
    }
  }
}
